# API environment variables — copy to apps/api/.env and fill in.
# Validated by Zod on boot (apps/api/src/config/env.validation.ts).
# Invalid env exits the process.

# ─── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (Postgres) ─────────────────────────────────────
# Local dev: docker-compose maps Postgres to 5433
# Production: use Supabase Transaction pooler URL
DATABASE_URL="postgresql://ticketbot:ticketbot@localhost:5433/ticketbot?schema=public"

# ─── Redis (BullMQ — currently stubbed but required) ─────────
# Local dev: docker-compose maps Redis to 6380
# Production: Railway Redis add-on or Upstash
REDIS_URL="redis://localhost:6380"

# ─── Supabase ────────────────────────────────────────────────
# From Supabase project Settings → API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
# Service role key — backend ONLY, never put in NEXT_PUBLIC_*
# Used by users.service.ts for the provisioning saga
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─── Bot session JWT (HS256) ─────────────────────────────────
# Min 32 chars random. Generate with: openssl rand -base64 48
JWT_SECRET="generate-a-random-32-plus-char-secret-here"

# ─── Telegram Bot ────────────────────────────────────────────
# From @BotFather. Use a SEPARATE bot for production vs dev.
BOT_TOKEN="000000000:placeholder-bot-token-from-botfather"
TELEGRAM_BOT_USERNAME="dernek_organizer_bot"

# ─── Public URLs ─────────────────────────────────────────────
# API_URL must be publicly reachable in production — the bot
# uses this to register the Telegram webhook on boot.
# Localhost values keep the bot in long-polling mode for dev.
API_URL="http://localhost:3000"
WEB_URL="http://localhost:3001"

# ─── AI (Groq, OpenAI-compatible) ────────────────────────────
# Optional. Without it, /meetings/analyze returns 503 but the
# rest of the API still boots. Get from https://console.groq.com
GROQ_API_KEY=""

# ─── SMTP (optional) ─────────────────────────────────────────
# If unset, dev environment uses Ethereal test inbox.
# Production: use Resend, SendGrid, AWS SES, etc.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
SMTP_FROM_NAME="Dernek Yönetim Sistemi"
