{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "allowJs": true,
    "noEmit": true
  },
  "include": ["src/**/*", "next-env.d.ts", "next.config.ts"],
  "exclude": ["node_modules"]
}
