# Web environment variables — copy to apps/web/.env.local and fill in.
# Next.js automatically loads .env.local; .env is also supported.
#
# IMPORTANT: Only NEXT_PUBLIC_* variables reach the browser.
# Never put SUPABASE_SERVICE_ROLE_KEY or any secret here.

# ─── Supabase (client-side) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ─── API base URL ────────────────────────────────────────────
# Where the web app fetches from. Must include scheme.
# Production: https://api.yourdomain.com (no trailing slash)
NEXT_PUBLIC_API_URL="http://localhost:3000"
