# Database (used by libs/database)
DATABASE_URL="postgresql://ticketbot:ticketbot@localhost:5432/ticketbot?schema=public"

# Redis (used by API for BullMQ)
REDIS_URL="redis://localhost:6379"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Bot JWT signing (HS256, used by API for bot session tokens)
JWT_SECRET="your-bot-jwt-secret-min-32-chars-long"

# Telegram Bot
BOT_TOKEN="your-telegram-bot-token"

# URLs
API_URL="http://localhost:3000"
WEB_URL="http://localhost:3001"

# OpenAI (used by libs/ai)
OPENAI_API_KEY="your-openai-api-key"

# Next.js public vars (used by apps/web)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_API_URL="http://localhost:3000"
