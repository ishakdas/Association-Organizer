generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  SYSTEM_ADMIN
  ASSOCIATION_MANAGER
  ASSOCIATION_SECRETARY
  ASSOCIATION_MEMBER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ReminderFrequency {
  NONE
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskActivityAction {
  CREATED
  REASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  DUE_DATE_CHANGED
  DESCRIPTION_CHANGED
  TITLE_CHANGED
  REMINDER_CHANGED
  REMINDER_SENT
  ASSIGNED_NOTIFIED
  ASSIGNMENT_ACCEPTED
  REASSIGNMENT_REQUESTED
  REASSIGNMENT_RESOLVED
}

enum EventType {
  CONFERENCE
  TALK
  SEMINAR
  IFTAR
  KANDIL
  MEETING
  CUSTOM
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum PendingBranchStatus {
  PENDING
  APPROVED
  REJECTED
}

// -----------------------------------------------------------------------------
// Reference: assignable titles (admin-managed)
// -----------------------------------------------------------------------------

model MemberTitleDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships AssociationMembership[]

  @@map("member_title_definitions")
}

// -----------------------------------------------------------------------------
// User & Auth
// -----------------------------------------------------------------------------

model User {
  id                    String    @id @default(cuid())
  supabaseUserId        String?   @unique
  email                 String?   @unique
  fullName              String
  phone                 String?
  address               String?
  isActive              Boolean   @default(true)
  onboardingCompletedAt DateTime?
  mustChangePassword    Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  memberships         AssociationMembership[]
  assignedTasks       Task[]            @relation("TaskAssignee")
  createdTasks        Task[]            @relation("TaskCreator")
  watchedTasks        Task[]            @relation("TaskWatcher")
  createdMeetings     MeetingNote[]     @relation("MeetingCreator")
  attendedMeetings    MeetingAttendee[]
  createdAssociations Association[]     @relation("AssociationsCreated")
  taskActivities      TaskActivity[]    @relation("TaskActivityActor")
  createdEvents       Event[]           @relation("EventCreator")
  telegramAccount     TelegramAccount?
  aiSuggestions       AiSuggestion[]
  savedSuggestions    SavedSuggestion[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model PendingBranchRegistration {
  id         String              @id @default(cuid())
  email      String              @unique
  fullName   String
  phone      String?
  city       String              @default("")
  district   String              @default("")
  message    String?
  status     PendingBranchStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([status])
  @@map("pending_branch_registrations")
}

model TelegramAccount {
  id         String  @id @default(cuid())
  telegramId BigInt  @unique
  username   String?
  firstName  String?
  userId     String  @unique

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_accounts")
}

model TelegramLinkToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("telegram_link_tokens")
}

// -----------------------------------------------------------------------------
// Association (Dernek Sicili)
// -----------------------------------------------------------------------------

model Association {
  id           String  @id @default(cuid())
  name         String
  shortName    String?
  taxNumber    String? @unique
  foundedAt    DateTime
  address      String?
  city         String
  district     String
  phone        String?
  email        String
  website      String?
  logoUrl      String?
  activityArea String
  memberCount  Int     @default(0)
  isActive     Boolean @default(true)
  notes        String?

  createdById String
  createdBy   User   @relation("AssociationsCreated", fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships         AssociationMembership[]
  tasks               Task[]
  meetings            MeetingNote[]
  events              Event[]
  eventRoleDefinitions EventRoleDefinition[]
  aiSuggestions       AiSuggestion[]

  @@index([city])
  @@index([isActive])
  @@index([createdById])
  @@index([deletedAt])
  @@map("associations")
}

model AssociationMembership {
  id            String    @id @default(cuid())
  userId        String
  associationId String
  role          UserRole
  titleId       String?
  customTitle   String?
  joinedAt      DateTime  @default(now())
  leftAt        DateTime?
  isActive      Boolean   @default(true)
  deletedAt     DateTime?

  user        User                   @relation(fields: [userId], references: [id])
  association Association            @relation(fields: [associationId], references: [id])
  title       MemberTitleDefinition? @relation(fields: [titleId], references: [id])

  eventAssignments EventAssignment[]

  @@unique([userId, associationId, role])
  @@index([associationId, role])
  @@index([userId])
  @@index([deletedAt])
  @@map("association_memberships")
}

// -----------------------------------------------------------------------------
// Tasks
// -----------------------------------------------------------------------------

model Task {
  id            String  @id @default(cuid())
  associationId String
  title         String
  description   String?

  assignedToUserId String
  assignedById     String
  watcherUserId    String?

  status   TaskStatus   @default(PENDING)
  priority TaskPriority @default(MEDIUM)

  dueDate           DateTime?
  reminderAt        DateTime?
  reminderFrequency ReminderFrequency @default(NONE)

  notifiedViaTelegram Boolean   @default(false)
  notifiedViaWhatsapp Boolean   @default(false)
  notifiedViaEmail    Boolean   @default(false)
  lastNotifiedAt      DateTime?

  // Dispute: assignee flagged the task as wrongly assigned. Manager
  // resolves from the web (reassign or dismiss) — flips back to false.
  disputed   Boolean   @default(false)
  disputedAt DateTime?

  sourceMeetingNoteId String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  deletedAt   DateTime?

  association       Association   @relation(fields: [associationId], references: [id], onDelete: Cascade)
  assignedTo        User          @relation("TaskAssignee", fields: [assignedToUserId], references: [id])
  assignedBy        User          @relation("TaskCreator", fields: [assignedById], references: [id])
  watcher           User?         @relation("TaskWatcher", fields: [watcherUserId], references: [id], onDelete: SetNull)
  sourceMeetingNote MeetingNote?  @relation(fields: [sourceMeetingNoteId], references: [id])
  activities        TaskActivity[]

  @@index([associationId, status])
  @@index([assignedToUserId, status])
  @@index([assignedToUserId, associationId, status])
  @@index([watcherUserId])
  @@index([dueDate])
  @@index([associationId, disputed])
  @@index([deletedAt])
  @@map("tasks")
}

// Append-only audit trail for a Task. One row per state change
// (assignment, status flip, due-date move, etc.). Read-only from the
// app's perspective — never updated, never soft-deleted; if the parent
// task is hard-deleted, activities cascade.
model TaskActivity {
  id        String             @id @default(cuid())
  taskId    String
  actorId   String
  action    TaskActivityAction
  payload   Json               @default("{}")
  createdAt DateTime           @default(now())

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation("TaskActivityActor", fields: [actorId], references: [id])

  @@index([taskId, createdAt])
  @@index([actorId])
  @@map("task_activities")
}

// -----------------------------------------------------------------------------
// Meeting Notes
// -----------------------------------------------------------------------------

model MeetingNote {
  id            String   @id @default(cuid())
  associationId String
  title         String
  content       String
  meetingDate   DateTime
  createdById   String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  association  Association       @relation(fields: [associationId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("MeetingCreator", fields: [createdById], references: [id])
  attendees    MeetingAttendee[]
  derivedTasks Task[]

  @@index([associationId, meetingDate])
  @@index([deletedAt])
  @@map("meeting_notes")
}

model MeetingAttendee {
  id            String @id @default(cuid())
  meetingNoteId String
  userId        String

  meetingNote MeetingNote @relation(fields: [meetingNoteId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@unique([meetingNoteId, userId])
  @@index([userId])
  @@map("meeting_attendees")
}

// -----------------------------------------------------------------------------
// Events (Etkinlik & Program Yönetimi)
// -----------------------------------------------------------------------------

// Per-association role catalog for event responsibilities (e.g. "Ses Sistemi",
// "İkram", "Karşılama"). Each association curates its own list — separate
// from MemberTitleDefinition which is system-wide.
model EventRoleDefinition {
  id            String  @id @default(cuid())
  associationId String
  name          String
  description   String?
  sortOrder     Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  association Association       @relation(fields: [associationId], references: [id], onDelete: Cascade)
  assignments EventAssignment[]

  @@unique([associationId, name])
  @@index([associationId, deletedAt])
  @@map("event_role_definitions")
}

model Event {
  id            String  @id @default(cuid())
  associationId String
  title         String
  description   String?
  type          EventType @default(CUSTOM)
  location      String?

  startsAt      DateTime
  endsAt        DateTime?

  // When the bot should DM each assignee. Per-event, set at creation.
  notifyAt      DateTime

  // Recurrence — for weekly sohbet, monthly kandil, etc. Master row stores
  // the rule; the scheduler computes the next occurrence after each
  // notification fires. Assignments stay attached to the master event.
  recurrenceType     RecurrenceType @default(NONE)
  recurrenceInterval Int            @default(1)
  recurrenceEndsAt   DateTime?

  // Set true once the bot has DM'd assignees for the current occurrence.
  // For recurring events the scheduler resets this when it advances.
  notificationSent Boolean @default(false)

  createdById String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  association Association       @relation(fields: [associationId], references: [id], onDelete: Cascade)
  createdBy   User              @relation("EventCreator", fields: [createdById], references: [id])
  assignments EventAssignment[]
  programItems EventProgramItem[]

  @@index([associationId, startsAt])
  @@index([associationId, deletedAt])
  @@index([notifyAt])
  @@map("events")
}

// One row per (event, member, role). A member can hold multiple roles in
// the same event (e.g. ses + karşılama) — each is a separate row. The
// role is either a catalog reference (roleDefinitionId) or a free-form
// custom string; uniqueness is enforced in the service layer because
// Postgres can't express "(eventId, membershipId, COALESCE(roleDefId,
// customRole))" as a unique constraint cleanly.
model EventAssignment {
  id               String  @id @default(cuid())
  eventId          String
  membershipId     String
  roleDefinitionId String?
  customRole       String?
  notes            String?

  notificationSent Boolean   @default(false)
  notifiedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event          Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  membership     AssociationMembership @relation(fields: [membershipId], references: [id])
  roleDefinition EventRoleDefinition?  @relation(fields: [roleDefinitionId], references: [id])

  @@index([eventId])
  @@index([membershipId])
  @@index([roleDefinitionId])
  @@map("event_assignments")
}

// External events cached from municipal websites (e.g. Gebze Belediyesi).
// Fetched periodically and filtered by association district on read.
model ExternalEvent {
  id          String   @id @default(cuid())
  source      String   // e.g. "gebze_belediyesi"
  externalId  String   // original id from source
  title       String
  category    String
  location    String
  eventDate   DateTime
  eventTime   String?
  description String?
  detailUrl   String
  imageUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, externalId])
  @@index([source, eventDate])
  @@map("external_events")
}

// AI-generated Islamic event suggestions stored for persistence, feedback, and learning.
model AiSuggestion {
  id                    String   @id @default(cuid())
  associationId         String
  period                String   // weekly | monthly
  targetAudience        String   // all | middle_school | high_school

  title                 String
  description           String   @db.Text
  category              String   // sohbet | egitim | kultur | genclik | aile | sosyal_sorumluluk | ibadet
  keyTopics             String[]
  resourcesNeeded       String
  estimatedParticipants String

  islamicSession        Json?
  schedule              Json?
  socialContent         Json?

  // Generation metadata for learning & A/B testing
  metadata              Json?   // { temperature, perspective, fewShotCount, promptVersion }

  createdById           String
  createdAt             DateTime @default(now())

  association           Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  createdBy             User        @relation(fields: [createdById], references: [id])
  feedback              AiSuggestionFeedback?
  savedBy               SavedSuggestion[]

  @@index([associationId, createdAt])
  @@map("ai_suggestions")
}

// Feedback on AI suggestions to improve future recommendations.
model AiSuggestionFeedback {
  id                 String   @id @default(cuid())
  suggestionId       String   @unique
  rating             Int
  isHelpful          Boolean?
  comment            String?
  likedCategories    String[] // which categories the user liked
  dislikedCategories String[] // which categories the user disliked
  createdAt          DateTime @default(now())

  suggestion    AiSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@map("ai_suggestion_feedbacks")
}

// Versioned prompt templates for A/B testing and admin editing.
model PromptTemplate {
  id        String   @id @default(cuid())
  key       String   // e.g. "suggest-islamic-events", "generate-event-schedule"
  version   Int      @default(1)
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, version])
  @@index([key, isActive])
  @@map("prompt_templates")
}

// User-saved suggestions for later use.
model SavedSuggestion {
  id            String   @id @default(cuid())
  userId        String
  suggestionId  String
  note          String?
  createdAt     DateTime @default(now())

  @@unique([userId, suggestionId])
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestion    AiSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([suggestionId])
  @@map("saved_suggestions")
}

// Structured program items for an event (schedule / agenda).
model EventProgramItem {
  id            String   @id @default(cuid())
  eventId       String
  startTime     String   // "14:00"
  duration      String   // "30 dk"
  title         String
  description   String?
  order         Int      @default(0)

  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_program_items")
}
