generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  SYSTEM_ADMIN
  ASSOCIATION_MANAGER
  ASSOCIATION_SECRETARY
  ASSOCIATION_MEMBER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ReminderFrequency {
  NONE
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskActivityAction {
  CREATED
  REASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  DUE_DATE_CHANGED
  DESCRIPTION_CHANGED
  TITLE_CHANGED
  REMINDER_CHANGED
  REMINDER_SENT
}

// -----------------------------------------------------------------------------
// Reference: assignable titles (admin-managed)
// -----------------------------------------------------------------------------

model MemberTitleDefinition {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships AssociationMembership[]

  @@map("member_title_definitions")
}

// -----------------------------------------------------------------------------
// User & Auth
// -----------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  supabaseUserId String?   @unique
  email          String?   @unique
  fullName       String
  phone          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  memberships         AssociationMembership[]
  assignedTasks       Task[]            @relation("TaskAssignee")
  createdTasks        Task[]            @relation("TaskCreator")
  watchedTasks        Task[]            @relation("TaskWatcher")
  createdMeetings     MeetingNote[]     @relation("MeetingCreator")
  attendedMeetings    MeetingAttendee[]
  createdAssociations Association[]     @relation("AssociationsCreated")
  taskActivities      TaskActivity[]    @relation("TaskActivityActor")
  telegramAccount     TelegramAccount?

  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model TelegramAccount {
  id         String  @id @default(cuid())
  telegramId BigInt  @unique
  username   String?
  firstName  String?
  userId     String  @unique

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_accounts")
}

model TelegramLinkToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("telegram_link_tokens")
}

// -----------------------------------------------------------------------------
// Association (Dernek Sicili)
// -----------------------------------------------------------------------------

model Association {
  id           String  @id @default(cuid())
  name         String
  shortName    String?
  taxNumber    String? @unique
  foundedAt    DateTime
  address      String?
  city         String
  district     String
  phone        String?
  email        String
  website      String?
  logoUrl      String?
  activityArea String
  memberCount  Int     @default(0)
  isActive     Boolean @default(true)
  notes        String?

  createdById String
  createdBy   User   @relation("AssociationsCreated", fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships AssociationMembership[]
  tasks       Task[]
  meetings    MeetingNote[]

  @@index([city])
  @@index([isActive])
  @@index([createdById])
  @@index([deletedAt])
  @@map("associations")
}

model AssociationMembership {
  id            String    @id @default(cuid())
  userId        String
  associationId String
  role          UserRole
  titleId       String?
  customTitle   String?
  joinedAt      DateTime  @default(now())
  leftAt        DateTime?
  isActive      Boolean   @default(true)
  deletedAt     DateTime?

  user        User                   @relation(fields: [userId], references: [id])
  association Association            @relation(fields: [associationId], references: [id])
  title       MemberTitleDefinition? @relation(fields: [titleId], references: [id])

  @@unique([userId, associationId, role])
  @@index([associationId, role])
  @@index([userId])
  @@index([deletedAt])
  @@map("association_memberships")
}

// -----------------------------------------------------------------------------
// Tasks
// -----------------------------------------------------------------------------

model Task {
  id            String  @id @default(cuid())
  associationId String
  title         String
  description   String?

  assignedToUserId String
  assignedById     String
  watcherUserId    String?

  status   TaskStatus   @default(PENDING)
  priority TaskPriority @default(MEDIUM)

  dueDate           DateTime?
  reminderAt        DateTime?
  reminderFrequency ReminderFrequency @default(NONE)

  notifiedViaTelegram Boolean   @default(false)
  notifiedViaWhatsapp Boolean   @default(false)
  notifiedViaEmail    Boolean   @default(false)
  lastNotifiedAt      DateTime?

  sourceMeetingNoteId String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  deletedAt   DateTime?

  association       Association   @relation(fields: [associationId], references: [id], onDelete: Cascade)
  assignedTo        User          @relation("TaskAssignee", fields: [assignedToUserId], references: [id])
  assignedBy        User          @relation("TaskCreator", fields: [assignedById], references: [id])
  watcher           User?         @relation("TaskWatcher", fields: [watcherUserId], references: [id], onDelete: SetNull)
  sourceMeetingNote MeetingNote?  @relation(fields: [sourceMeetingNoteId], references: [id])
  activities        TaskActivity[]

  @@index([associationId, status])
  @@index([assignedToUserId, status])
  @@index([assignedToUserId, associationId, status])
  @@index([watcherUserId])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("tasks")
}

// Append-only audit trail for a Task. One row per state change
// (assignment, status flip, due-date move, etc.). Read-only from the
// app's perspective — never updated, never soft-deleted; if the parent
// task is hard-deleted, activities cascade.
model TaskActivity {
  id        String             @id @default(cuid())
  taskId    String
  actorId   String
  action    TaskActivityAction
  payload   Json               @default("{}")
  createdAt DateTime           @default(now())

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation("TaskActivityActor", fields: [actorId], references: [id])

  @@index([taskId, createdAt])
  @@index([actorId])
  @@map("task_activities")
}

// -----------------------------------------------------------------------------
// Meeting Notes
// -----------------------------------------------------------------------------

model MeetingNote {
  id            String   @id @default(cuid())
  associationId String
  title         String
  content       String
  meetingDate   DateTime
  createdById   String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  association  Association       @relation(fields: [associationId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("MeetingCreator", fields: [createdById], references: [id])
  attendees    MeetingAttendee[]
  derivedTasks Task[]

  @@index([associationId, meetingDate])
  @@index([deletedAt])
  @@map("meeting_notes")
}

model MeetingAttendee {
  id            String @id @default(cuid())
  meetingNoteId String
  userId        String

  meetingNote MeetingNote @relation(fields: [meetingNoteId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@unique([meetingNoteId, userId])
  @@index([userId])
  @@map("meeting_attendees")
}
